      "slots": 1
    },
    {
      "id": "mnadn9rq",
      "itemType": "sundry",
      "itemTypeId": "",
      "magicItemType": "magicMisc",
      "name": "Wand of Knock",
      "bonus": 0,
      "bonusNote": "",
      "attackNote": "",
      "features": "This wand allows a character to cast the Knock spell if that spell is on their spell list (even if they don't know that spell). Failing to cast the spell from the wand does not impact the ability to cast known spells. After a failed casting attempt with a wand, the wand stops working until you rest. On a critical failure, the wand permanently breaks and casters with mishap tables must roll a mishap. ",
      "spellDesc": "KNOCK (Tier 2, Wizard), DC 10 to cast, Duration: Instant, Range: Near \n A door, window, gate, chest, or portal you can see within range instantly opens, defeating all mundane locks and barriers. This spell creates a loud knock audible to all within earshot.",
      "benefits": "",
      "curses": "",
      "hasPersonality": false,
      "properties": [],
      "slots": 1
    },
    {
