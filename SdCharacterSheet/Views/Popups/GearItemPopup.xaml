<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="SdCharacterSheet.Views.Popups.GearItemPopup">
    <VerticalStackLayout Padding="20" Spacing="12">
        <Label Text="Item" FontAttributes="Bold" FontSize="18" />

        <Label Text="Name" />
        <Entry x:Name="NameEntry" Placeholder="Item name" />

        <Label Text="Slots" />
        <Entry x:Name="SlotsEntry" Keyboard="Numeric" Placeholder="1" />

        <Label Text="Type" />
        <Entry x:Name="ItemTypeEntry" Placeholder="weapon, armor, etc." />

        <Label Text="Note" />
        <Entry x:Name="NoteEntry" Placeholder="Optional notes" />

        <!-- Free Carry toggle (D-04) -->
        <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
            <CheckBox x:Name="FreeCarryCheckBox" />
            <Label Text="Free Carry" VerticalOptions="Center" />
        </HorizontalStackLayout>

        <Button Text="Save" Clicked="OnSave" />
        <Button Text="Delete" Clicked="OnDelete" TextColor="Red" />
    </VerticalStackLayout>
</toolkit:Popup>
